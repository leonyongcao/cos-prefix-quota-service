# COS 基础配置
COS_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxxxx
COS_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
COS_REGION=ap-guangzhou
COS_APPID=1250000000
COS_DEFAULT_BUCKET=examplebucket-1250000000

# STS 临时密钥配置
# 建议 1800-7200 秒。有效期越长，客户端重复申请密钥越少，但泄露风险也更高。
STS_DURATION_SECONDS=1800

# 是否在 /uploads/apply 返回前缀级 STS 临时密钥。
# true：适合大文件分块上传或批量上传，但客户端拿到 token 后理论上可写该 prefix 下任意对象，必须配合业务约束。
# false：只返回单对象 presigned_put_url，更接近严格单文件 quota 控制。
ISSUE_STS_ON_APPLY=true

# 服务配置
DATABASE_URL=sqlite:///./quota.db
AUTO_DELETE_OVER_QUOTA_OBJECT=false
PRESIGNED_URL_EXPIRES=1800

# MetaInsight 智能检索（数据万象 CI）
# 用于在创建 quota 与 reconcile 时秒级聚合 prefix 下真实用量，
# 取代 ListObjects 全量遍历。未开通时自动降级到 ListObjects。
USE_METAINSIGHT=false
METAINSIGHT_DATASET_NAME=cos-quota-dataset
METAINSIGHT_REGION=ap-guangzhou
